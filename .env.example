PORT=3000

# Origin allowed to call this API from a browser (CORS), e.g. the origin
# IRASS is served from: https://irass.example.com. Defaults to "*" (any
# origin) which is fine for local development but should be locked down
# once IRASS's real origin is known.
ALLOWED_ORIGIN=*

# Requires `ollama serve` running locally with OLLAMA_MODEL pulled,
# e.g. `ollama pull qwen2.5-coder:7b`. No API key, no internet -- runs
# entirely offline.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_NUM_CTX=4096
OLLAMA_MAX_TABLES=20

# OpenAI-compatible server hosting Gemma 3 27B (e.g. vLLM on an H200 box).
GEMMA_BASE_URL=http://localhost:3001
GEMMA_MODEL=gemma-3-27b

# Model id used for POST /v1/embeddings on the same server, for semantic
# schema-relevance filtering (src/llm/schemaFilter.ts). Defaults to
# GEMMA_MODEL if unset. If the server doesn't support embeddings, schema
# filtering falls back to keyword matching automatically.
GEMMA_EMBEDDING_MODEL=gemma-3-27b

# Model id from src/llm/models.ts used when the client doesn't pick one.
DEFAULT_MODEL_ID=qwen2.5-coder-7b

# Required to unlock POST /ask/confirm (running a real INSERT/UPDATE/DELETE).
# Leave blank to keep destructive queries disabled.
ADMIN_PASSWORD=

# Primary database, selectable as database:"nextgendb" (see src/databases.ts).
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=nextgendb
PG_USER=postgres
PG_PASSWORD=

# Id from src/databases.ts used when a caller (web UI or API) doesn't pick one.
DEFAULT_DATABASE_ID=nextgendb

# Second selectable database, registered as database:"db2-placeholder" --
# placeholder until real connection details exist. Fill these in and it
# becomes usable with no other code changes; leave blank and selecting it
# returns a clear "not configured" error instead of a raw connection failure.
DB2_HOST=
DB2_PORT=5432
DB2_DATABASE=
DB2_USER=
DB2_PASSWORD=
